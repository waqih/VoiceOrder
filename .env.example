# ===========================================
# VoiceOrder AI - Environment Variables
# Copy to .env and fill in values:
#   cp .env.example .env
# ===========================================

# --- Database ---
POSTGRES_USER=voiceorder
POSTGRES_PASSWORD=localdevpassword
POSTGRES_DB=voiceorder
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://voiceorder:localdevpassword@postgres:5432/voiceorder

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Server (FastAPI) ---
SERVER_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
SERVER_DEBUG=true
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_CORS_ORIGINS=http://localhost:3000

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Agent (LiveKit) ---
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# --- Deepgram (STT) ---
DEEPGRAM_API_KEY=

# --- OpenAI (LLM) ---
OPENAI_API_KEY=

# --- Anthropic (LLM fallback) ---
ANTHROPIC_API_KEY=

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=

# --- Cartesia (TTS alternative) ---
CARTESIA_API_KEY=

# --- Twilio (Telephony) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Telnyx (Telephony) ---
TELNYX_API_KEY=
SIP_PHONE_NUMBER=

# --- Email (Resend - https://resend.com) ---
# Free tier: 100 emails/day. Leave empty to log reset links to console.
RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000

# --- Dashboard (Next.js) ---
# For local dev: set to http://localhost:8000 (direct backend calls)
# For production/Vercel: leave empty (uses Next.js rewrites via BACKEND_URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side only: backend URL for Next.js rewrites proxy
# For Docker: http://server:8000 | For Vercel: http://YOUR_SERVER_IP:8000
BACKEND_URL=
NEXT_PUBLIC_APP_NAME=VoiceOrder AI
