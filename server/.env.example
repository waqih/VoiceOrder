# Database (use 'localhost' for local dev, 'postgres' for Docker)
DATABASE_URL=postgresql+asyncpg://voiceorder:localdevpassword@localhost:5432/voiceorder

# Redis (use 'localhost' for local dev, 'redis' for Docker)
REDIS_URL=redis://localhost:6379/0

# JWT (CHANGE THIS in production!)
JWT_SECRET_KEY=change-me-in-production

# CORS (comma-separated origins allowed to call the API)
SERVER_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Email - Resend (https://resend.com - free tier: 100 emails/day)
# Leave empty to log reset links to console instead of sending email
RESEND_API_KEY=

# Frontend URL (used in password reset email links)
FRONTEND_URL=http://localhost:3000
